{
  "name": "@orbitali/mcp",
  "version": "0.1.6",
  "description": "Orbitali MCP server for configuring voice agents from coding agents.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/orbitaliai/mcp"
  },
  "bugs": {
    "url": "https://github.com/orbitaliai/mcp/issues"
  },
  "homepage": "https://github.com/orbitaliai/mcp#readme",
  "bin": {
    "orbitali-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun src/index.ts",
    "dev:http": "bun src/http.ts",
    "start": "bun dist/index.js",
    "start:http": "bun dist/http.js",
    "build": "rm -rf dist && bun build src/index.ts src/http.ts --outdir dist --target bun && tsc -p tsconfig.build.json",
    "prepack": "bun run build",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/bun": "^1.3.3",
    "typescript": "^5.9.3"
  }
}
